# ============================================================================
# WAYMESH COPILOT - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local (frontend) and .env (backend)
# Fill in all required values for your environment
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION (Next.js)
# ─────────────────────────────────────────────────────────────────────────

# Anthropic API Key - Get from https://console.anthropic.com
# Required for Claude AI chat functionality
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Backend API URL
# Development: http://localhost:8000
# Production: https://api.waymesh.ai
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────
# BACKEND CONFIGURATION (Python)
# ─────────────────────────────────────────────────────────────────────────

# Environment
# Options: development, staging, production
ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────

# Supabase Project URL
# Get from: https://app.supabase.com/projects
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (backend use only)
# Has admin privileges for data manipulation
# Get from: Project Settings → API → Service Role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2MjAwMDAwMDAsImV4cCI6MTk5OTk5OTk5OX0.your-token-here

# Supabase Anon Key (public use)
# Limited permissions, safe for client-side use
# Get from: Project Settings → API → Anon Key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjIwMDAwMDAwLCJleHAiOjE5OTk5OTk5OTl9.your-token-here

# ─────────────────────────────────────────────────────────────────────────
# AI PROVIDER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

# Anthropic API Key (same as frontend, required for backend)
# Used for embedding generation and prompt processing
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Claude Model Selection
# Recommended: claude-3-5-sonnet-20241022
# Options: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ─────────────────────────────────────────────────────────────────────────
# EXTERNAL API KEYS (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────

# Google Places API Key
# For destination and supplier data enrichment
# Get from: https://console.cloud.google.com/
# Optional: Only needed if using Google Places integration
GOOGLE_PLACES_API_KEY=AIza...

# ─────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────────

# Enable Debug Mode
# Set to true for development, false for production
DEBUG=true

# API Request Timeout (seconds)
API_TIMEOUT=30

# Max conversation history length
MAX_HISTORY_ITEMS=50

# Embedding Chunk Size (characters)
CHUNK_SIZE=1000

# Chunk Overlap (characters)
CHUNK_OVERLAP=200

# RAG Similarity Threshold (0-1)
# Higher values = more similar results required
RAG_SIMILARITY_THRESHOLD=0.7

# Max RAG Results
RAG_MAX_RESULTS=5
